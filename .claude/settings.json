{
  "permissions": {
    "allow": [
      "edit"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(unlink *)",
      "Bash(Remove-Item *)",
      "Bash(* | rm *)",
      "Bash(* && rm *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/intercept-delete.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-path.sh\""
          }
        ]
      }
    ]
  },
  "disableBypassPermissionsMode": "disable"
}
